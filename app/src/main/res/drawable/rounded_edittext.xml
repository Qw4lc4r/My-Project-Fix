<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- фон -->
    <solid android:color="#5A838383" />

    <!-- рамка (по желанию) -->
    <stroke
        android:width="1dp"
        android:color="#CCCCCC" />

    <!-- радиус скругления -->
    <corners android:radius="12dp" />

    <!-- внутренние отступы -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" />
</shape>
