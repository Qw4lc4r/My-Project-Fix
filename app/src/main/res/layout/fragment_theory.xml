<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTheoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Что такое типы данных"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <TextView
            android:id="@+id/tvTheoryContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Содержание теории..."
            android:textSize="16sp"
            android:textColor="#333333"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Пример кода:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#666666"
            android:layout_marginTop="16dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#263238"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <TextView
                android:id="@+id/tvCodeExample"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="int x = 10;"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:background="#263238" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
